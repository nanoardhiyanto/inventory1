<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventaris App</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    .glass { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
    .loader { border-top-color: #3498db; animation: spinner 1.5s linear infinite; }
    @keyframes spinner { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  </style>
</head>
<body class="bg-slate-100 min-h-screen">

  <!-- Loading Overlay -->
  <div id="loader" class="fixed inset-0 bg-white/80 z-[100] hidden flex items-center justify-center">
    <div class="loader ease-linear rounded-full border-4 border-t-4 border-gray-200 h-12 w-12 mb-4"></div>
  </div>

  <!-- Login Page -->
  <div id="login-page" class="flex items-center justify-center min-h-screen p-4">
    <div class="glass p-8 rounded-2xl shadow-xl w-full max-w-md">
      <div class="text-center mb-8">
        <div class="bg-blue-600 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
          <i class="fas fa-warehouse text-white text-2xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-gray-800">Sistem Inventaris</h1>
        <p class="text-gray-500">Silakan login untuk melanjutkan</p>
      </div>
      <div class="space-y-4">
        <input type="password" id="password" placeholder="Masukkan Password" class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
        <button onclick="login()" class="w-full bg-blue-600 text-white p-3 rounded-lg font-semibold hover:bg-blue-700 transition">Login</button>
      </div>
    </div>
  </div>

  <!-- Main App (Hidden by Default) -->
  <div id="main-app" class="hidden">
    <!-- Navbar -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center gap-2">
            <i class="fas fa-boxes-stacked text-blue-600 text-xl"></i>
            <span class="font-bold text-lg text-gray-800 uppercase tracking-wider">Inventory Logistik Migas</span>
          </div>
          <button onclick="logout()" class="text-red-500 hover:bg-red-50 p-2 rounded-lg"><i class="fas fa-sign-out-alt"></i></button>
        </div>
      </div>
    </nav>

    <!-- Bottom Navigation (Mobile Friendly) -->
    <div class="fixed bottom-0 left-0 right-0 bg-white border-t flex justify-around p-2 md:relative md:border-none md:max-w-7xl md:mx-auto md:mt-4">
      <button onclick="showPage('dashboard')" class="nav-btn flex flex-col items-center p-2 text-blue-600" id="btn-dashboard">
        <i class="fas fa-chart-line text-xl"></i>
        <span class="text-xs">Dashboard</span>
      </button>
      <button onclick="showPage('barang')" class="nav-btn flex flex-col items-center p-2 text-gray-400" id="btn-barang">
        <i class="fas fa-list text-xl"></i>
        <span class="text-xs">Daftar</span>
      </button>
      <button onclick="showPage('masuk')" class="nav-btn flex flex-col items-center p-2 text-gray-400" id="btn-masuk">
        <i class="fas fa-arrow-down text-xl"></i>
        <span class="text-xs">Masuk</span>
      </button>
      <button onclick="showPage('keluar')" class="nav-btn flex flex-col items-center p-2 text-gray-400" id="btn-keluar">
        <i class="fas fa-arrow-up text-xl"></i>
        <span class="text-xs">Keluar</span>
      </button>
    </div>

    <!-- Content Area -->
    <main class="max-w-7xl mx-auto p-4 pb-24 md:pb-8">
      
      <!-- DASHBOARD PAGE -->
      <section id="page-dashboard" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-blue-500">
            <p class="text-gray-500 text-sm">Total Jenis Barang</p>
            <h2 class="text-3xl font-bold text-gray-800" id="stat-total-jenis">0</h2>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-green-500">
            <p class="text-gray-500 text-sm">Total Stok Fisik</p>
            <h2 class="text-3xl font-bold text-gray-800" id="stat-total-items">0</h2>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-red-500">
            <p class="text-gray-500 text-sm">Stok Menipis (< 10)</p>
            <h2 class="text-3xl font-bold text-gray-800" id="stat-low-stock">0</h2>
          </div>
        </div>
      </section>

      <!-- DAFTAR BARANG PAGE -->
      <section id="page-barang" class="hidden space-y-4">
        <div class="flex justify-between items-center">
          <h2 class="text-xl font-bold">Data Master Barang</h2>
          <button onclick="openModal('modal-barang')" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm">+ Barang</button>
        </div>
        <div class="bg-white rounded-xl shadow-sm overflow-x-auto">
          <table class="w-full text-left">
            <thead class="bg-gray-50 border-b">
              <tr>
                <th class="p-4 text-xs font-semibold text-gray-600 uppercase">Kode/Nama</th>
                <th class="p-4 text-xs font-semibold text-gray-600 uppercase">Kategori</th>
                <th class="p-4 text-xs font-semibold text-gray-600 uppercase">Stok</th>
                <th class="p-4 text-xs font-semibold text-gray-600 uppercase">Rak</th>
              </tr>
            </thead>
            <tbody id="table-barang-body" class="divide-y text-sm">
              <!-- Data injected here -->
            </tbody>
          </table>
        </div>
      </section>

      <!-- BARANG MASUK PAGE -->
      <section id="page-masuk" class="hidden max-w-2xl mx-auto">
        <div class="bg-white p-6 rounded-xl shadow-sm space-y-4">
          <h2 class="text-xl font-bold text-green-600">Input Barang Masuk</h2>
          <div class="space-y-3">
            <select id="in-kode" class="w-full p-3 border rounded-lg select-barang"></select>
            <input type="number" id="in-jumlah" placeholder="Jumlah Masuk" class="w-full p-3 border rounded-lg">
            <input type="text" id="in-keterangan" placeholder="Keterangan (Supplier/PO)" class="w-full p-3 border rounded-lg">
            <button onclick="submitTransaksi('masuk')" class="w-full bg-green-600 text-white p-3 rounded-lg font-bold">Simpan Transaksi</button>
          </div>
        </div>
      </section>

      <!-- BARANG KELUAR PAGE -->
      <section id="page-keluar" class="hidden max-w-2xl mx-auto">
        <div class="bg-white p-6 rounded-xl shadow-sm space-y-4">
          <h2 class="text-xl font-bold text-red-600">Input Barang Keluar</h2>
          <div class="space-y-3">
            <select id="out-kode" class="w-full p-3 border rounded-lg select-barang"></select>
            <input type="number" id="out-jumlah" placeholder="Jumlah Keluar" class="w-full p-3 border rounded-lg">
            <input type="text" id="out-keterangan" placeholder="Tujuan / Nama Pengambil" class="w-full p-3 border rounded-lg">
            <button onclick="submitTransaksi('keluar')" class="w-full bg-red-600 text-white p-3 rounded-lg font-bold">Simpan Transaksi</button>
          </div>
        </div>
      </section>

    </main>
  </div>

  <!-- MODAL ADD BARANG -->
  <div id="modal-barang" class="fixed inset-0 bg-black/50 z-[110] hidden flex items-center justify-center p-4">
    <div class="bg-white w-full max-w-md rounded-2xl overflow-hidden">
      <div class="p-6 border-b flex justify-between items-center">
        <h3 class="font-bold">Tambah Barang Baru</h3>
        <button onclick="closeModal('modal-barang')"><i class="fas fa-times"></i></button>
      </div>
      <div class="p-6 space-y-3">
        <input type="text" id="m-kode" placeholder="Kode Barang (Contoh: BRG-001)" class="w-full p-3 border rounded-lg">
        <input type="text" id="m-nama" placeholder="Nama Barang" class="w-full p-3 border rounded-lg">
        <input type="text" id="m-kategori" placeholder="Kategori (Elektronik, Alat Tulis, dll)" class="w-full p-3 border rounded-lg">
        <div class="grid grid-cols-2 gap-2">
          <input type="number" id="m-stok" placeholder="Stok Awal" class="w-full p-3 border rounded-lg">
          <input type="text" id="m-satuan" placeholder="Satuan (Pcs/Box)" class="w-full p-3 border rounded-lg">
        </div>
        <input type="text" id="m-lokasi" placeholder="Lokasi Rak (Contoh: A-12)" class="w-full p-3 border rounded-lg">
        <button onclick="saveBarang()" class="w-full bg-blue-600 text-white p-3 rounded-lg font-bold">Simpan Ke Master</button>
      </div>
    </div>
  </div>

  <script>
    let globalData = [];

    function toggleLoader(show) {
      document.getElementById('loader').classList.toggle('hidden', !show);
    }

    function login() {
      const pass = document.getElementById('password').value;
      toggleLoader(true);
      google.script.run.withSuccessHandler(res => {
        toggleLoader(false);
        if (res) {
          document.getElementById('login-page').classList.add('hidden');
          document.getElementById('main-app').classList.remove('hidden');
          refreshData();
        } else {
          alert('Password Salah!');
        }
      }).checkLogin(pass);
    }

    function logout() {
      window.location.reload();
    }

    function showPage(pageId) {
      ['dashboard', 'barang', 'masuk', 'keluar'].forEach(p => {
        document.getElementById('page-' + p).classList.add('hidden');
        document.getElementById('btn-' + p).classList.replace('text-blue-600', 'text-gray-400');
      });
      document.getElementById('page-' + pageId).classList.remove('hidden');
      document.getElementById('btn-' + pageId).classList.replace('text-gray-400', 'text-blue-600');
      
      if(pageId === 'dashboard') loadStats();
      if(pageId === 'barang') renderTable();
      if(pageId === 'masuk' || pageId === 'keluar') updateSelects();
    }

    function refreshData() {
      toggleLoader(true);
      google.script.run.withSuccessHandler(data => {
        globalData = data;
        loadStats();
        toggleLoader(false);
      }).getDataBarang();
    }

    function loadStats() {
      google.script.run.withSuccessHandler(stats => {
        document.getElementById('stat-total-jenis').innerText = stats.totalJenis;
        document.getElementById('stat-total-items').innerText = stats.totalItems;
        document.getElementById('stat-low-stock').innerText = stats.lowStock;
      }).getDashboardStats();
    }

    function renderTable() {
      const body = document.getElementById('table-barang-body');
      body.innerHTML = globalData.map(b => `
        <tr class="hover:bg-gray-50 transition">
          <td class="p-4 font-medium">
            <div class="text-blue-600 text-[10px] font-bold">${b.kode}</div>
            <div>${b.nama}</div>
          </td>
          <td class="p-4 text-gray-500">${b.kategori}</td>
          <td class="p-4">
            <span class="font-bold ${b.stokAkhir < 10 ? 'text-red-500' : 'text-gray-800'}">${b.stokAkhir}</span>
            <span class="text-[10px] text-gray-400">${b.satuan}</span>
          </td>
          <td class="p-4 text-gray-600 italic">${b.lokasi}</td>
        </tr>
      `).join('');
    }

    function updateSelects() {
      const selects = document.querySelectorAll('.select-barang');
      const options = '<option value="">-- Pilih Barang --</option>' + 
        globalData.map(b => `<option value="${b.kode}">${b.kode} - ${b.nama}</option>`).join('');
      selects.forEach(s => s.innerHTML = options);
    }

    function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
    function closeModal(id) { document.getElementById(id).classList.add('hidden'); }

    function saveBarang() {
      const obj = {
        kode: document.getElementById('m-kode').value,
        nama: document.getElementById('m-nama').value,
        kategori: document.getElementById('m-kategori').value,
        stokAwal: document.getElementById('m-stok').value,
        satuan: document.getElementById('m-satuan').value,
        lokasi: document.getElementById('m-lokasi').value
      };
      
      if(!obj.kode || !obj.nama) return alert('Kode dan Nama wajib diisi');

      toggleLoader(true);
      google.script.run.withSuccessHandler(() => {
        closeModal('modal-barang');
        refreshData();
      }).addBarang(obj);
    }

    function submitTransaksi(type) {
      const prefix = type === 'masuk' ? 'in-' : 'out-';
      const obj = {
        kode: document.getElementById(prefix + 'kode').value,
        jumlah: document.getElementById(prefix + 'jumlah').value,
        info: document.getElementById(prefix + 'keterangan').value
      };

      if(!obj.kode || !obj.jumlah) return alert('Data tidak lengkap');

      toggleLoader(true);
      google.script.run.withSuccessHandler(() => {
        alert('Data Transaksi Berhasil Disimpan');
        document.getElementById(prefix + 'jumlah').value = '';
        document.getElementById(prefix + 'keterangan').value = '';
        refreshData();
      }).addTransaction(type, obj);
    }

  </script>
</body>
</html>
